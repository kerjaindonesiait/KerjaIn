# ─── Local development (copy to .env) ─────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000

# Optional explicit API URL for OAuth (defaults to http://localhost:3000 in dev)
# API_PUBLIC_URL=http://localhost:3000

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Facebook OAuth — https://developers.facebook.com/apps/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/auth/facebook/callback

# Email (without RESEND_API_KEY, links print to backend console in dev)
RESEND_API_KEY=
EMAIL_FROM="KerjaIn <noreply@kerjain.id>"

# Admin panel — comma-separated emails allowed to access /admin
ADMIN_EMAILS=you@example.com

# Google Maps — enable Maps JavaScript API, restrict key to your domain
VITE_GOOGLE_MAPS_API_KEY=

# ─── Production ───────────────────────────────────────────────────────────────
# See .env.production.example — set FRONTEND_URL=https://kerjaindonesia.com
# and API_PUBLIC_URL / VITE_API_URL to your live API host on the server & in CI.
