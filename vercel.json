{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/agents.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/agent-instructions.md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/masuk", "destination": "/index.html" },
    { "source": "/daftar", "destination": "/index.html" },
    { "source": "/daftar-tukang", "destination": "/index.html" },
    { "source": "/post-job", "destination": "/index.html" },
    { "source": "/bayar", "destination": "/index.html" },
    { "source": "/dasbor-tukang", "destination": "/index.html" },
    { "source": "/tasks", "destination": "/index.html" },
    { "source": "/pekerjaan-saya", "destination": "/index.html" },
    { "source": "/ulasan-saya", "destination": "/index.html" },
    { "source": "/lupa-sandi", "destination": "/index.html" },
    { "source": "/atur-ulang-sandi", "destination": "/index.html" },
    { "source": "/verifikasi-email", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/akun", "destination": "/index.html" },
    { "source": "/akun/:path*", "destination": "/index.html" },
    { "source": "/pesan", "destination": "/index.html" },
    { "source": "/pesan/:path*", "destination": "/index.html" },
    { "source": "/auth/:path*", "destination": "/index.html" },
    { "source": "/tukang/:path*", "destination": "/index.html" }
  ]
}
