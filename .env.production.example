# Production template — copy values to your host (never commit real secrets).
# Vercel (frontend): set only VITE_* vars below.
# API server (api.kerjaindonesia.com): set all backend vars + NODE_ENV=production on the process.

# ─── Frontend (Vercel build) ─────────────────────────────────────────────────
VITE_API_URL=https://api.kerjaindonesia.com
VITE_GOOGLE_MAPS_API_KEY=

# ─── Backend (API host only — NOT needed on Vercel) ──────────────────────────
FRONTEND_URL=https://kerjaindonesia.com
API_PUBLIC_URL=https://api.kerjaindonesia.com
CORS_ORIGINS=https://www.kerjaindonesia.com
PORT=3000
COOKIE_SECURE=true

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.kerjaindonesia.com/auth/google/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://api.kerjaindonesia.com/auth/facebook/callback

RESEND_API_KEY=
EMAIL_FROM="KerjaIn <noreply@kerjaindonesia.com>"

ADMIN_EMAILS=admin@kerjaindonesia.com
